# =============================================================================
# Required — copy to .env.local and fill in before running the app
# =============================================================================

# Public site URL (no trailing slash) — auth redirects, Stripe return URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Custom domain for shareable links (invites, etc.). When set, overrides *.vercel.app.
NEXT_PUBLIC_CANONICAL_APP_URL=

# Supabase (Project Settings → API)
# Local dev + tests use the shared DEV/TEST project. Production Supabase creds
# live ONLY in Vercel — never point a local .env at production.
# See docs/database-environments.md.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Production project ref — enables the fail-closed guard that stops a non-prod
# runtime (local dev/tests/preview) from talking to production. Safe to set in
# every env (it is a public identifier, not a secret).
AXIS_PROD_SUPABASE_REF=
# Supabase Postgres — for `npm run db:apply-sql` and admin schema bootstrap
# Project Settings → Database → database password
Supabase_Database_Password=
# Aliases also supported: SUPABASE_DATABASE_PASSWORD, SUPABASE_DB_PASSWORD

# Stripe (Developers → API keys + Connect + Webhooks)
#
# Two separate payment flows:
#   • Manager subscriptions (Pro/Business) — Apple Pay, Link, and card via Stripe Checkout
#     (dynamic payment methods; see docs/stripe-apple-pay-subscriptions.md)
# For resident portal payments (rent, utilities, application fees) — ACH, card, and Link via Connect
#
# For resident payments: enable ACH Direct Debit and Cards under Settings → Payment methods.
# Live keys (sk_live_) require HTTPS return URLs — Connect bank linking will fail on http://localhost.
# Local dev: use sk_test_/pk_test_ keys, or an HTTPS tunnel (ngrok) with NEXT_PUBLIC_APP_URL=https://….
# Webhook events for ACH: checkout.session.completed, checkout.session.async_payment_succeeded
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Manager subscription price IDs (Free tier does not use Stripe)
# Optional overrides (must be price_… ids). Checkout resolves prices from Stripe by lookup_key:
# axis_manager_pro_monthly, axis_manager_pro_annual, axis_manager_business_monthly, axis_manager_business_annual
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_BUSINESS_ANNUAL=
# After setting STRIPE_SECRET_KEY, run: npm run stripe:setup-plans (tags lookup_keys in Stripe)
# Optional: Stripe Payment Method Configuration for subscription checkout only (Apple Pay + card)
# STRIPE_SUBSCRIPTION_PAYMENT_METHOD_CONFIGURATION=pmc_...

# =============================================================================
# Optional — enable specific features; app runs without these
# =============================================================================

# Stripe Dashboard → Coupons → coupon ID (coup_…). Applied when switching monthly → annual.
STRIPE_COUPON_SWITCH_TO_ANNUAL=

# Stripe Dashboard → Promotion codes → Promotion code ID (promo_…).
# When set, FIRSTFREE/FREEFIRST on Partner pricing (Pro monthly) auto-applies first month free.
STRIPE_PROMOTION_CODE_ID_FIRST_MONTH_FREE=

# Server-only admin bootstrap key for /auth/create-account (admin role).
# Dev: defaults to "prakrit-admin-register" if unset. Production: MUST be set to a
# strong random value or admin registration is disabled (fails closed). Never use NEXT_PUBLIC_.
AXIS_ADMIN_REGISTER_KEY=

# Server-only payment-waiver code that skips Stripe checkout on /partner/pricing.
# Dev: defaults to "FREE100" if unset. Production: only active when set to a strong
# random value (waiver disabled when unset). Never use NEXT_PUBLIC_.
AXIS_PAYMENT_WAIVER_CODE=

# After setting Supabase URL + service role, sync an admin account (local CLI):
#   node --env-file=.env.local scripts/ensure-admin-account.mjs you@example.com 'YourPassword'
#   npm run admin:sync-account -- you@example.com 'YourPassword'

# `npm run test:seed` (tests/helpers/seed-test-db.mjs) provisions the canonical
# dev/test-DB accounts (admin/manager/manager2/resident/vendor). Each defaults to
# a fixed test.axis.local address + password (see the script) — only set these to
# point the seed at different addresses/passwords.
# E2E_ADMIN_EMAIL=
# E2E_ADMIN_PASSWORD=
# E2E_MANAGER_EMAIL=
# E2E_MANAGER_PASSWORD=
# E2E_RESIDENT_EMAIL=
# E2E_RESIDENT_PASSWORD=
# E2E_VENDOR_EMAIL=
# E2E_VENDOR_PASSWORD=

# Production-only portal demo seed (scripts/seed-production-portal.mjs). NEVER set
# these in dev/test or Vercel Preview — Production scope only. Pull prod creds with:
#   vercel env pull .env.production.local --environment=production
# Run: ALLOW_PRODUCTION_SEED=1 AXIS_PROD_DEMO_PASSWORD='…' \
#   node --env-file=.env.production.local scripts/seed-production-portal.mjs
# AXIS_PRODUCTION_SEED_KEY=
# AXIS_PROD_DEMO_PASSWORD=

# Optional dedicated Supabase project for the public /demo sandbox (isolated from production).
# When unset, /demo uses client-side localStorage seed data. When set, seed the demo
# project with: ALLOW_DEMO_SEED=1 AXIS_DEMO_SEED_PASSWORD='…' npm run seed:demo
# See docs/database-environments.md.
NEXT_PUBLIC_DEMO_SUPABASE_URL=
NEXT_PUBLIC_DEMO_SUPABASE_ANON_KEY=
# Server-only (Vercel Production scope). Same project as NEXT_PUBLIC_DEMO_SUPABASE_*.
DEMO_SUPABASE_URL=
DEMO_SUPABASE_SERVICE_ROLE_KEY=
# Password for @axis.local demo accounts in the demo Supabase project.
AXIS_DEMO_SEED_PASSWORD=

# Hide /demo nav, landing CTA, and redirect /demo → / when set to false (default: true).
# NEXT_PUBLIC_AXIS_PUBLIC_DEMO_ENABLED=false

# Resend — transactional email (resident welcome, payment reminders, inbox)
# https://resend.com → API Keys. Use a verified domain in production for RESEND_FROM.
RESEND_API_KEY=
RESEND_FROM=

# Vercel Cron auth (vercel.json). Protects /api/cron/*; if unset, cron routes are unauthenticated.
CRON_SECRET=

# Twilio — SMS for welcome emails, payment reminders, inbox (silently skipped if unset)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Vendor messaging agent — the single platform number (E.164) the agent texts
# vendors from; inbound replies hit /api/webhooks/twilio/sms (set that URL as
# the number's Messaging webhook + enable Advanced Opt-Out; A2P 10DLC required).
# TWILIO_WEBHOOK_URL only when a proxy rewrites the request origin (must be the
# exact URL configured in the Twilio console for signature validation).
AXIS_AGENT_SMS_FROM=
TWILIO_WEBHOOK_URL=

# Push notifications (native apps) — Firebase Cloud Messaging service account.
# From Firebase console → Project settings → Service accounts → Generate new private key.
# Keep the private key's "\n" escapes intact when pasting on one line.
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# Tenant screening (Certn) — pay-per-report credit + background checks for rental applications
# https://certn.co — enable API access, then set webhook URL to {NEXT_PUBLIC_APP_URL}/api/webhooks/screening/certn
SCREENING_PROVIDER=certn
CERTN_API_KEY=
CERTN_WEBHOOK_SECRET=
# Optional overrides (defaults: api.certn.co, /pm/v1/applications/quick, $39.99 pass-through)
# CERTN_API_BASE_URL=https://api.certn.co
# CERTN_APPLICATIONS_PATH=/pm/v1/applications/quick
SCREENING_COST_CENTS=3999

# Applicant background check (Checkr Tenant API) — manager-paid via Checkr billing.
# https://checkr-tenant-api-docs.redocly.app — server-side secret key ONLY
# (Bearer token), never exposed. One host for test and live keys.
# Use a Checkr *test* key (ckr_sk_test_…) on staging and in Vercel preview so
# the signed-in portal exercises the real sandbox. Screening Download PDF always
# proxies Checkr's official report bytes (never a locally generated PDF).
# The public `/demo` sandbox uses `/api/demo/screening/background-check/document`
# with the committed static file only (public/samples/checkr-tenant-report.pdf).
# Signed-in portal routes may still fetch sandbox PDFs via CHECKR_API_KEY below.
CHECKR_API_KEY=
BACKGROUND_CHECK_API_KEY=
# Optional: pin a package — one of starter | essential | complete (default essential).
# CHECKR_PACKAGE=essential
# Optional: override host (default https://tenant.checkr.com/api).
# CHECKR_API_BASE_URL=https://tenant.checkr.com/api
# Webhook signing secret(s) from Checkr Developer → Webhooks (shown once at creation).
# Production LIVE endpoint: https://www.axis-seattle-housing.com/api/webhooks/screening/checkr
# CHECKR_WEBHOOK_SECRET=
# Optional second secret if you also register a TEST-mode webhook (e.g. on staging).
# CHECKR_WEBHOOK_SECRET_TEST=
# Optional: Axis platform fee per Checkr order (default $5.00), charged to manager Stripe card.
# CHECKR_AXIS_SURCHARGE_CENTS=500
# CHECKR_SIMULATE=1
# Optional: pinned sandbox order/report for `/demo` + offline simulate PDF download.
# CHECKR_SAMPLE_ORDER_ID=ord_test_...
# CHECKR_SAMPLE_REPORT_RESOURCE_ID=rp_test_...
# Flat fee (USD cents) charged to the manager per screening run (default $29.99).
# CHECKR_SCREENING_COST_CENTS=2999

# AI agent (Axis Assistant) — Anthropic SDK reads this key directly via `new Anthropic()`.
# Required for the in-app assistant; without it the agent chat endpoint fails.
ANTHROPIC_API_KEY=
# Model routing: the agent picks a model per turn based on task complexity to
# save tokens. Each tier is overridable below (defaults shown). AXIS_AGENT_MODEL
# is a global hard override — when set, it forces that one model for every tier.
AXIS_AGENT_MODEL=
AXIS_AGENT_MODEL_SIMPLE=    # trivial turns; default claude-haiku-4-5
AXIS_AGENT_MODEL_STANDARD=  # ordinary turns; default claude-sonnet-4-6
AXIS_AGENT_MODEL_COMPLEX=   # analytical/multi-part turns; default claude-opus-4-8

# PostHog — product analytics (server-side). No-ops when POSTHOG_KEY is unset.
# Never send PII or secrets as event properties.
POSTHOG_KEY=
# Optional host override (defaults to https://us.i.posthog.com).
POSTHOG_HOST=
# PostHog — client-side analytics & autocapture. No-ops when the token is unset,
# so the whole frontend analytics layer (pageviews, autocaptured clicks, named
# events) silently does nothing until this is set.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sign in with Apple (web). Shown on web by default alongside Google on sign-in and
# create-account. Set to false to hide the web button. Native iOS always shows Apple
# when Google is offered.
#
# Laptop/web OAuth is configured in Supabase + Apple Developer (Services ID + secret),
# not via env vars — see docs/apple-sign-in-setup.md.
# NEXT_PUBLIC_APPLE_SIGN_IN_ENABLED=false

# Langfuse — AI agent observability (traces). No-ops unless both keys are set.
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
# Optional host override (defaults to https://us.cloud.langfuse.com).
LANGFUSE_BASE_URL=

# SMS relay pool + phone verification (all optional; features no-op without them).
# TWILIO_VERIFY_SERVICE_SID: phone-OTP via Twilio Verify (no A2P campaign needed);
# unset falls back to hashed OTP sent from the work number.
# TWILIO_MESSAGING_SERVICE_SID: Messaging Service bought relay numbers join to
# inherit the A2P campaign (required before the pool can buy numbers).
# SMS_RELAY_POOL_AUTOBUY=1 enables the hourly relay-number buy loop — leave unset
# while the Twilio A2P brand is Sole Proprietor (one local number allowed).
TWILIO_VERIFY_SERVICE_SID=
TWILIO_MESSAGING_SERVICE_SID=
SMS_RELAY_POOL_AUTOBUY=

# Claw Messenger — PRODUCTION PropLane messaging (single shared agent line)
# One phone (+12053690702) runs leasing, resident, and manager two-way SMS.
# Keep a gateway running in every environment: npm run claw:gateway
# Point AXIS_CLAW_WEBHOOK_URL at this deploy's /api/webhooks/claw-messenger
# One-time phone routes: npm run claw:setup
# Docs: https://www.clawmessenger.com/docs
# Twilio per-manager numbers are a future endeavour — keep Claw enabled for now.
CLAW_MESSENGER_ENABLED=1
CLAW_MESSENGER_API_KEY=
CLAW_MESSENGER_AGENT_PHONE=+12053690702
CLAW_MESSENGER_WS_URL=wss://claw-messenger.onrender.com/ws
CLAW_MESSENGER_HTTP_BASE=https://claw-messenger.onrender.com
# Optional ADDITIVE roster override (e.g. an ops cell not yet fully provisioned).
# Leave empty: shared-line managers are DB-registered via profiles.sms_from_number
# (see docs/agents/sms-system.md). Sandbox emails are never re-admitted.
CLAW_MESSENGER_MANAGER_EMAILS=
# Quiet window (seconds) before the gateway forwards buffered prospect texts (default 150)
CLAW_MESSENGER_DEBOUNCE_SECONDS=
# How often (ms) the gateway refreshes manager phone hashes from
# /api/webhooks/claw-messenger/manager-phones (default 5 min)
CLAW_MESSENGER_MANAGER_PHONES_REFRESH_MS=
# Optional HMAC for gateway → /api/webhooks/claw-messenger
CLAW_MESSENGER_WEBHOOK_SECRET=
# Set to 1 only when replaying WS history should auto-reply again
CLAW_MESSENGER_PROCESS_REPLAYS=
# Public origin used inside SMS deep links (defaults to production domain; never localhost)
CLAW_MESSENGER_LINK_ORIGIN=https://www.axis-seattle-housing.com
# Client CTAs / work-number UI — must stay 1 while Claw is the messaging system
NEXT_PUBLIC_CLAW_MESSENGER_AGENT_PHONE=+12053690702
NEXT_PUBLIC_CLAW_MESSENGER_ENABLED=1
# Manager personal phones that receive forwarded inbound leasing texts via Claw
CLAW_MESSENGER_MANAGER_FORWARD_PHONES=+15103098345
# Default resident phone when a manager texts the agent line with no open thread yet
CLAW_MESSENGER_DEFAULT_RESIDENT_PHONE=+15105794001
# Pin a real Twilio number on test managers during `npm run test:seed` (future Twilio path)
# TEST_MANAGER_SMS_FROM_NUMBER=+1XXXXXXXXXX
