# Public site URL (no trailing slash) — used for Stripe redirect URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (Developers → API keys + Products → Prices)
STRIPE_SECRET_KEY=
# Optional: publishable key for future client-side Stripe.js (Elements, etc.)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Connect platform take (basis points; 100 = 1%, 50 = 0.5%). Used when creating PaymentIntents / Checkout with transfer_data.destination.
AXIS_PLATFORM_APPLICATION_FEE_BPS=100
# Application fees: renters use Checkout at /rent/apply; managers need profiles.stripe_connect_account_id + livemode Connect.
AXIS_PLATFORM_RENT_BPS=50

# Price IDs for manager checkout (subscription mode). Free tier does not use Stripe.
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_BUSINESS_ANNUAL=

# Optional: Stripe Dashboard → Coupons → coupon ID (starts with coup_…). Applied when switching an existing subscription from monthly to annual (e.g. flat $20 off once — configure duration in the coupon).
STRIPE_COUPON_SWITCH_TO_ANNUAL=

# Optional: Stripe Dashboard → Promotion codes → copy Promotion code ID (promo_…).
# When set, entering FIRSTFREE/FREEFIRST on Partner pricing (Pro monthly) auto-applies first month free in Checkout.
STRIPE_PROMOTION_CODE_ID_FIRST_MONTH_FREE=

# Optional: admin bootstrap key for /auth/create-account (admin role)
NEXT_PUBLIC_AXIS_ADMIN_REGISTER_KEY=axis-admin-register

# After setting URL + service role above, sync an admin password + profile roles (local CLI):
#   node --env-file=.env.local scripts/ensure-admin-account.mjs you@example.com 'YourPassword'
#   npm run admin:sync-account -- you@example.com 'YourPassword'   # load env in shell first, or use --env-file with Node 20+

# Resident portal QA: comma-separated emails that always see lease/payments/work orders/inbox before application_approved is true in profiles.
RESIDENT_PORTAL_FULL_ACCESS_EMAILS=
# Optional suffix match, e.g. @yourdomain.test — combined with resident role and signed-in user.
RESIDENT_PORTAL_TEST_EMAIL_DOMAIN=
# Resend — transactional email (resident welcome from Applications, etc.)
# https://resend.com → API Keys. Use a verified domain in production for RESEND_FROM.
RESEND_API_KEY=
# e.g. "Axis Housing <welcome@yourdomain.com>" — test mode may use onboarding@resend.dev (see Resend docs).
RESEND_FROM=
