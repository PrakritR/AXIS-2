# Public site URL (no trailing slash) — used for Stripe redirect URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (Developers → API keys + Products → Prices)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Price IDs for manager checkout (subscription mode). Create matching recurring prices in Stripe.
STRIPE_PRICE_FREE_MONTHLY=
STRIPE_PRICE_FREE_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_BUSINESS_ANNUAL=

# Optional: admin bootstrap key for /auth/create-account (admin role)
NEXT_PUBLIC_AXIS_ADMIN_REGISTER_KEY=axis-demo-admin

# Resident portal QA: comma-separated emails that always see lease/payments/work orders/inbox before application_approved is true in profiles.
RESIDENT_PORTAL_FULL_ACCESS_EMAILS=
# Optional suffix match, e.g. @yourdomain.test — combined with resident role and signed-in user.
RESIDENT_PORTAL_TEST_EMAIL_DOMAIN=
# Development only: set to 1 so every user with profiles.role = resident gets the full portal without DB approval.
RESIDENT_PORTAL_DEV_FULL_ACCESS=
