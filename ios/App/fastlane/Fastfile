default_platform(:ios)

# Axis iOS release automation.
#
# The `beta` lane builds the app and ships it to TestFlight. It authenticates with
# an App Store Connect API key (never an Apple ID / password), auto-manages signing
# in the cloud via `-allowProvisioningUpdates`, and picks the next build number as
# (latest TestFlight build + 1) so uploads are always monotonic. `MARKETING_VERSION`
# (1.0) stays whatever the project holds — bump it in Xcode for a new marketing rev.
#
# Required env (set as GitHub Actions secrets — see .github/workflows/ios-testflight.yml):
#   ASC_KEY_ID     App Store Connect API key id
#   ASC_ISSUER_ID  App Store Connect issuer id
#   ASC_KEY_P8     base64 of the AuthKey_XXXX.p8 file contents
require "base64"
require "fileutils"

platform :ios do
  desc "Build and upload a new build to TestFlight"
  lane :beta do
    key_id = ENV.fetch("ASC_KEY_ID")
    issuer_id = ENV.fetch("ASC_ISSUER_ID")

    # Materialize the .p8 to disk so we can hand its path to BOTH fastlane and,
    # crucially, xcodebuild's -allowProvisioningUpdates (which needs explicit
    # -authenticationKey* flags — passing key_content alone leaves the archive
    # step with "No Accounts / no provisioning profiles" as it can't call Apple).
    key_dir = File.expand_path(".keys", __dir__)
    FileUtils.mkdir_p(key_dir)
    key_path = File.join(key_dir, "AuthKey_#{key_id}.p8")
    File.write(key_path, Base64.decode64(ENV.fetch("ASC_KEY_P8")))

    api_key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_filepath: key_path,
    )

    next_build = (latest_testflight_build_number(
      api_key: api_key,
      app_identifier: "com.axisseattlehousing.app",
      initial_build_number: 6,
    ).to_i + 1).to_s

    build_app(
      project: "App.xcodeproj",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      # Cloud-managed signing: xcodebuild creates/fetches the distribution cert +
      # App Store profile headlessly, authenticated by the API key passed here.
      xcargs: [
        "-allowProvisioningUpdates",
        "-authenticationKeyPath", key_path,
        "-authenticationKeyID", key_id,
        "-authenticationKeyIssuerID", issuer_id,
        "CURRENT_PROJECT_VERSION=#{next_build}",
      ].join(" "),
      export_options: {
        signingStyle: "automatic",
        teamID: "8FH3GVHCZ9",
      },
      output_directory: "build",
      output_name: "Axis.ipa",
      clean: true,
    )

    upload_to_testflight(
      api_key: api_key,
      # Don't block the CI job waiting for Apple's server-side processing.
      skip_waiting_for_build_processing: true,
    )
  ensure
    File.delete(key_path) if defined?(key_path) && key_path && File.exist?(key_path)
  end
end
