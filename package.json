{
  "name": "axis-2",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:seed": "node --env-file=.env.test tests/helpers/seed-test-db.mjs",
    "test:cleanup": "node --env-file=.env.test tests/helpers/cleanup-test-db.mjs",
    "check": "npm run lint && npm run test:unit && npm run build",
    "lockfile:verify": "node scripts/verify-lockfile.mjs",
    "seed:env": "node scripts/seed-worktree-env.mjs",
    "admin:sync-account": "node scripts/ensure-admin-account.mjs",
    "admin:ensure-demo-manager": "node scripts/ensure-demo-manager-account.mjs",
    "admin:purge-managers": "node scripts/purge-non-demo-managers.mjs",
    "stripe:setup-plans": "node --env-file=.env.local scripts/setup-stripe-plan-prices.mjs --write-env",
    "stripe:listen": "node scripts/stripe-listen.mjs",
    "stripe:validate": "node --env-file=.env.local scripts/stripe-validate-env.mjs",
    "stripe:validate-live": "node --env-file=.env.local scripts/stripe-validate-env.mjs --expect-live"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@radix-ui/react-accordion": "^1.2.14",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-navigation-menu": "^1.2.16",
    "@radix-ui/react-slot": "^1.3.0",
    "@stripe/react-stripe-js": "^6.2.0",
    "@stripe/stripe-js": "^9.2.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "next": "^16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.0.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "twilio": "^6.0.2",
    "langfuse": "^3.38.0",
    "posthog-js": "^1.205.0",
    "posthog-node": "^4.10.0",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
