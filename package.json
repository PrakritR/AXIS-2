{
  "name": "axis-2",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "postinstall": "patch-package",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:seed": "node --env-file=.env.test tests/helpers/seed-test-db.mjs",
    "seed:production": "node scripts/seed-production-portal.mjs",
    "seed:demo": "node scripts/seed-demo-supabase.mjs",
    "wipe:dev": "node scripts/wipe-dev-supabase.mjs",
    "wipe:demo": "node scripts/wipe-dev-supabase.mjs --demo",
    "wipe:test:all": "node --env-file=.env.test scripts/wipe-test-db-all.mjs",
    "test:cleanup": "node --env-file=.env.test tests/helpers/cleanup-test-db.mjs",
    "check": "npm run lint && npm run test:unit && npm run build",
    "db:link:dev": "supabase link --project-ref emstjswhotsnyksqhqyf",
    "db:new": "supabase migration new",
    "db:diff": "supabase db diff --linked",
    "db:push": "supabase db push",
    "db:pull": "supabase db pull",
    "db:baseline": "supabase migration repair --status applied $(ls supabase/migrations | sed -E 's/_.*//')",
    "db:status": "supabase migration list --linked",
    "lockfile:verify": "node scripts/verify-lockfile.mjs",
    "seed:env": "node scripts/seed-worktree-env.mjs",
    "seed:dev-account": "npx tsx scripts/seed-dev-manager-portfolio.ts",
    "admin:sync-account": "node scripts/ensure-admin-account.mjs",
    "admin:set-manager-plan": "node scripts/set-manager-plan.mjs",
    "admin:ensure-demo-manager": "node scripts/ensure-demo-manager-account.mjs",
    "admin:purge-managers": "node scripts/purge-non-demo-managers.mjs",
    "db:apply-sql": "node --env-file=.env.local scripts/apply-supabase-sql.mjs",
    "stripe:apple-pay-domains": "node --env-file=.env.local scripts/setup-stripe-apple-pay-domains.mjs",
    "apple:diagnose": "node --env-file=.env.local scripts/diagnose-apple-web-oauth.mjs",
    "apple:configure-web": "node scripts/configure-apple-web-oauth.mjs",
    "cap:sync": "cap sync",
    "cap:dev": "node scripts/cap-sync-dev.mjs",
    "cap:prod": "node scripts/cap-sync-prod.mjs",
    "cap:ios:run": "node scripts/cap-sync-dev.mjs && npx cap run ios",
    "cap:copy": "cap copy",
    "cap:ios": "cap open ios",
    "cap:android": "cap open android",
    "ship:preflight": "bash scripts/ship-preflight.sh",
    "scrape:apm": "node scripts/scrape-allpropertymanagement.mjs",
    "scrape:apm:quick": "node scripts/scrape-allpropertymanagement.mjs --quick",
    "scrape:apm:contacts": "node scripts/scrape-apm-contacts.mjs",
    "claw:gateway": "node --env-file=.env.local scripts/claw-messenger-gateway.mjs",
    "claw:setup": "node --env-file=.env.local scripts/setup-claw-messenger.mjs",
    "claw:assign-numbers": "node --env-file=.env.local scripts/assign-claw-leasing-numbers.mjs",
    "admin:backfill-work-numbers": "npx tsx --env-file=.env.local scripts/backfill-manager-work-numbers.ts",
    "setup:twilio-vercel": "node --env-file=.env.local scripts/sync-twilio-vercel-env.mjs",
    "setup:claw-manager-numbers": "node --env-file=.env.local scripts/stamp-claw-manager-numbers.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@capacitor-community/apple-sign-in": "^7.1.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@radix-ui/react-accordion": "^1.2.14",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-navigation-menu": "^1.2.16",
    "@radix-ui/react-slot": "^1.3.0",
    "@stripe/react-stripe-js": "^6.2.0",
    "@stripe/stripe-js": "^9.2.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "langfuse": "^3.38.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.22.0",
    "next": "^16.2.9",
    "pdf-lib": "^1.17.1",
    "pg": "^8.16.3",
    "posthog-js": "^1.205.0",
    "posthog-node": "^4.10.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "stripe": "^22.0.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "twilio": "^6.0.2",
    "ws": "^8.21.1",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/pg": "^8.15.6",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "patch-package": "^8.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
