    "san_francisco": {
      "city": "san_francisco",
      "state": "CA",
      "county": "City and County of San Francisco",
      "header_subtitle": "State of California · City and County of San Francisco",
      "governing_law": "California Civil Code and SF Administrative Code Chapter 37 where applicable",
      "municipal_compliance_ref": "SF Admin. Code Ch. 37 (Rent Ordinance)",
      "sample_lease": "san-francisco/sample-lease.md",
      "inherits_rules": ["federal", "california", "san_francisco"],
      "lease_signing_rule_ids": [
        "fed-lead-paint",
