        { "id": "prorate", "title": "5. Prorated First Month", "conditional": "lease_start not on 1st of month" },
        { "id": "deposit", "title": "Security Deposit & Move-In Charges", "merge_fields": ["security_deposit", "move_in_fee", "application_fee", "total_due_at_signing"], "disclosure_rules": ["wa-deposit-terms", "wa-movein-checklist", "seattle-deposit-installments", "wa-nonrefundable-fees"] },
        { "id": "returned_payments", "title": "Returned Payments" },
