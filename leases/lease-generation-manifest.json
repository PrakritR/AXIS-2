  "fee_validators": {
    "seattle": [
      {
        "id": "late_fee_cap",
        "rule_id": "seattle-late-fee-cap",
        "field": "late_fee_per_month_usd",
        "max": 10,
        "message": "Seattle caps rent late fees at $10/month (SMC 7.24.034). Current template uses $50 — must be corrected for Seattle properties."
      },
      {
        "id": "deposit_plus_movein_cap",
        "rule_id": "seattle-deposit-installments",
        "expression": "security_deposit + nonrefundable_move_in_fees <= monthly_rent",
        "message": "Combined security deposit and nonrefundable move-in fees may not exceed one month's rent."
      },
      {
        "id": "pet_deposit_cap",
        "rule_id": "seattle-deposit-installments",
        "expression": "pet_deposit <= 0.25 * monthly_rent",
        "message": "Pet deposit capped at 25% of monthly rent in Seattle."
      }
    ],
    "san_francisco": [
      {
        "id": "ab1482_font",
        "rule_id": "ca-ab1482-notice",
        "field": "ab1482_notice_font_pt",
        "min": 12,
        "message": "AB 1482 notice must be at least 12-point type."
      },
      {
        "id": "rent_ordinance_font",
        "rule_id": "sf-rent-ordinance-disclosure",
        "field": "rent_ordinance_notice_font_pt",
        "min": 12,
        "message": "SF Rent Ordinance disclosure must be at least 12-point type."
      }
    ]
  },
