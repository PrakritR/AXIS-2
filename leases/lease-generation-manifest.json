    "san_francisco": "src/lib/lease-templates/san-francisco.ts",
    "jurisdiction": "src/lib/lease-jurisdiction.ts",
    "config": "src/lib/lease-templates/types.ts"
  },
  "ai_disclaimer": {
    "text": "This lease was generated by AI. Please review carefully before sending to the tenant. This is not legal advice.",
    "placement": ["document_banner", "manager_notes_on_generate", "manager_ui_chip", "signing_modal_generated_only"]
  },
