    }
  },
  "derived_fields": {
    "city": {
      "source": "resolveLeaseJurisdiction()",
      "maps_to": "san_francisco | seattle | unsupported"
    },
    "collects_deposit": {
      "expression": "security_deposit_amount > 0",
      "sources": ["listing.securityDeposit", "application.managerSecurityDepositOverride"]
    },
    "has_nonrefundable_fee": {
      "expression": "move_in_fee > 0 OR other_nonrefundable_fee > 0",
      "sources": ["listing.moveInFee", "application.managerMoveInFeeOverride", "application.managerOtherCostAmount"]
    },
    "has_periodic_pest_service": {
      "source": "listing or property admin field (not yet in Axis — default false until captured)"
    },
    "shared_utility_metering": {
      "source": "listing or property admin field (not yet in Axis — default false until captured)"
    },
    "year_built": {
      "source": "property.yearBuilt or listing submission (not yet in Axis — required for lead paint rule)"
    },
    "is_rent_ordinance_covered": {
      "source": "sf-coverage-determination decision tree",
      "inputs": ["certificate_of_occupancy_date", "building_type", "owner_occupancy", "exemptions"]
    },
    "ab1482_exempt": {
      "source": "Attorney-configured or decision tree",
      "notes": "Single-family/condo not owned by corp/REIT; COO within 15 years; etc."
    }
  },
  "merge_fields": {
    "parties": {
      "landlord_entity": { "source": "listing.buildingName", "fallback": "[LANDLORD ENTITY NAME]" },
      "landlord_mailing_address": { "source": "listing.address + neighborhood + zip" },
      "resident_legal_name": { "source": "application.fullLegalName" },
      "resident_phone": { "source": "application.phone" },
      "resident_email": { "source": "application.email" },
      "resident_dob": { "source": "application.dateOfBirth" },
      "resident_employer": { "source": "application.employer" },
      "resident_job_title": { "source": "application.jobTitle" },
      "resident_monthly_income": { "source": "application.monthlyIncome" },
      "resident_current_address": { "source": "application.currentStreet, currentCity, currentState, currentZip" },
      "occupancy_count": { "source": "application.occupancyCount" },
      "pets": { "source": "application.pets" }
    },
    "premises": {
      "street_address": { "source": "property.address or listing.address" },
      "city_zip": { "source": "property.neighborhood, property.zip" },
      "room_label": { "source": "room choice → submission.rooms.name or property.unitLabel" },
      "full_premises_description": { "source": "buildingName + room name" },
      "house_overview": { "source": "listing.houseOverview or property.tagline" },
      "rrio_registration_number": { "source": "property.rrioNumber", "jurisdiction": "seattle" }
    },
    "financials": {
      "monthly_base_rent": {
        "source": "application.managerRentOverride OR room submission monthlyRent OR property.rentLabel"
      },
      "month_to_month_surcharge": { "fixed": 25, "when": "leaseTerm === Month-to-Month" },
      "utilities_estimate": {
        "source": "application.managerUtilitiesOverride OR room.utilitiesEstimate OR listing aggregate"
      },
      "application_fee": { "source": "listing.applicationFee" },
      "security_deposit": { "source": "application.managerSecurityDepositOverride OR listing.securityDeposit" },
      "move_in_fee": { "source": "application.managerMoveInFeeOverride OR listing.moveInFee" },
      "other_cost_label": { "source": "application.managerOtherCostLabel" },
      "other_cost_amount": { "source": "application.managerOtherCostAmount" },
      "total_due_at_signing": { "computed": "deposit + move_in + other_nonrefundable" },
      "payment_methods": { "source": "listing zelle/venmo/stripe flags" }
    },
    "term": {
      "lease_term_label": { "source": "application.leaseTerm" },
      "lease_start": { "source": "application.leaseStart" },
      "lease_end": { "source": "application.leaseEnd", "month_to_month": "N/A or rolling" },
      "rental_type": { "source": "application.rentalType", "values": ["standard", "short_term"] },
      "short_term_daily_cost": { "source": "listing.shortTermDailyCost" },
      "short_term_deposit": { "source": "listing.shortTermDeposit" },
      "short_term_check_in": { "source": "application.shortTermCheckInTime" },
      "short_term_check_out": { "source": "application.shortTermCheckOutTime" }
    },
    "content_blocks": {
      "lease_terms_body": { "source": "listing.leaseTermsBody" },
      "shared_spaces": { "source": "listing.sharedSpaces + room access" },
      "amenities": { "source": "listing.amenitiesText" },
      "house_rules": { "source": "listing.houseRulesText" },
      "utilities_breakdown": {
        "source": "listing.leaseUtilities",
        "optional": true,
        "shape": "per-utility rows: kind (+ custom label), paidBy (included_in_rent | resident | manager), setUpBy (resident | manager), optional allowance and notes",
        "renders": "table in the Utilities & Services section; absent = standard prorated-share prose"
      },
      "pet_policy": { "derived": "property.petFriendly" }
    },
    "metadata": {
      "generated_at": { "source": "ISO timestamp at generation" },
      "lease_version": { "source": "pipeline row version counter" }
    }
  },
  "document_blueprint": {
    "standard_room_lease": {
      "title": "RESIDENTIAL ROOM RENTAL AGREEMENT",
      "sections": [
        { "id": "banner", "title": "AI review disclaimer", "required": true, "rule_ref": null },
        { "id": "parties", "title": "1. Parties", "merge_fields": ["landlord_entity", "resident_legal_name", "resident_phone", "resident_email", "resident_dob"] },
        { "id": "premises", "title": "2. Premises", "merge_fields": ["street_address", "room_label", "house_overview"], "disclosure_rules": ["sf-rent-ordinance-disclosure", "seattle-rrio"] },
