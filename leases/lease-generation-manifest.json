  "description": "Master data manifest for Axis AI lease generation in Seattle and San Francisco. Combines document structure, merge fields, fee validators, and references to disclosure-clause-rules.json. Not parsed at runtime in phase 1 — port into src/lib/lease-templates/ after attorney review.",
  "rules_catalog": "disclosure-clause-rules.json",
  "code_templates": {
    "router": "src/lib/generated-lease.ts",
    "html_builder": "src/lib/lease-templates/build-lease-html.ts",
